          "id": "contract-bride-ep3",
          "index": 3,
          "title": "His Cold Rules",
          "scenes": [
            {
              "image": "contract-bride/ep3/scene1.jpg",
              "caption": "Welcome to your new prison.",
              "durationSec": 11
            },
            {
              "image": "contract-bride/ep3/scene2.jpg",
              "caption": "Rule one: never touch me.",
              "durationSec": 7
            },
            {
              "image": "contract-bride/ep3/scene3.jpg",
              "caption": "He thinks he owns me.",
              "durationSec": 9
            },
            {
              "image": "contract-bride/ep3/scene4.jpg",
              "caption": "She wasn't supposed to fight back.",
              "durationSec": 7
            },
            {
              "image": "contract-bride/ep3/scene5.jpg",
              "caption": "Every rule protects a secret.",
              "durationSec": 7
            },
            {
              "image": "contract-bride/ep3/scene6.jpg",
              "caption": "He knew her. He lied.",
              "durationSec": 9
            },
            {
              "image": "contract-bride/ep3/scene7.jpg",
              "caption": "She didn't marry for money.",
              "durationSec": 7
            },
            {
              "image": "contract-bride/ep3/scene8.jpg",
